{% comment %}
  Montucky Moonshine — Trust Bar Snippet
  Usage: {% render 'trust-bar' %}
  Recommended placement: Below header, above first collection section.
  Also effective below the Add to Cart button on product pages.
{% endcomment %}

<style>
  .mm-trust-bar {
    background: #0d0d0b;
    border-top: 1px solid rgba(200,146,42,0.12);
    border-bottom: 1px solid rgba(200,146,42,0.12);
    padding: 1.25rem 1.5rem;
  }
  .mm-trust-bar-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .mm-trust-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #9e9a8f;
    font-family: 'Barlow Condensed', 'Barlow', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .mm-trust-item-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .mm-trust-divider {
    width: 1px;
    height: 1.25rem;
    background: rgba(200,146,42,0.2);
  }
  @media (max-width: 640px) {
    .mm-trust-bar-inner { gap: 1.25rem; }
    .mm-trust-divider { display: none; }
    .mm-trust-item { font-size: 0.65rem; }
  }
</style>

<div class="mm-trust-bar">
  <div class="mm-trust-bar-inner">
    <div class="mm-trust-item">
      <span class="mm-trust-item-icon">🚚</span>
      <span>Free shipping over $75</span>
    </div>
    <div class="mm-trust-divider"></div>
    <div class="mm-trust-item">
      <span class="mm-trust-item-icon">🏔️</span>
      <span>Handcrafted in Montana</span>
    </div>
    <div class="mm-trust-divider"></div>
    <div class="mm-trust-item">
      <span class="mm-trust-item-icon">⭐</span>
      <span>5-star rated by customers</span>
    </div>
    <div class="mm-trust-divider"></div>
    <div class="mm-trust-item">
      <span class="mm-trust-item-icon">🔒</span>
      <span>Secure checkout</span>
    </div>
    <div class="mm-trust-divider"></div>
    <div class="mm-trust-item">
      <span class="mm-trust-item-icon">↩️</span>
      <span>Easy returns</span>
    </div>
  </div>
</div>
